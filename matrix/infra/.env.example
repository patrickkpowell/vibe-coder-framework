# Decrypted from secrets.encrypted.yaml via SOPS at deploy time.
# Never commit a populated .env file.

# Matrix homeserver identity
MATRIX_SERVER_NAME=matrix.powellcompanies.com
MATRIX_PUBLIC_BASEURL=https://matrix.powellcompanies.com

# Synapse PostgreSQL (internal to matrix-net, never exposed to host)
MATRIX_POSTGRES_DB=synapse
MATRIX_POSTGRES_USER=synapse
MATRIX_POSTGRES_PASSWORD=

# Synapse registration shared secret (used to create accounts without open registration)
MATRIX_REGISTRATION_SHARED_SECRET=

# Bot identity
MATRIX_BOT_USER_ID=@notification-bot:matrix.powellcompanies.com
MATRIX_BOT_PASSWORD=
MATRIX_BOT_ACCESS_TOKEN=

# matrix-api bearer token (required on all /send requests)
MATRIX_API_KEY=

# MCP bearer token (for future reverse-proxy auth layer)
MATRIX_MCP_API_KEY=

# Notification destinations
# Default destination when caller omits 'destination'
MATRIX_DEFAULT_DESTINATION=home

# JSON map of friendly name -> Matrix room ID
# Populate after rooms are created.  Example:
# MATRIX_DESTINATIONS_JSON={"home":"!abc123:matrix.powellcompanies.com","home-alerts":"!def456:matrix.powellcompanies.com"}
MATRIX_DESTINATIONS_JSON={}

# Rate limit for matrix-api (format: N/minute, N/second, or N/hour)
MATRIX_RATE_LIMIT=30/minute

# MCP admin tools (create rooms, invite users) — disabled by default
MATRIX_MCP_ENABLE_ADMIN_TOOLS=false

# Timezone for Synapse container
TZ=America/Chicago
